# Portal DUIT — variáveis de ambiente
# Copia este ficheiro para `.env` em dev (e define estas mesmas variáveis no Railway em produção).

# Em produção tem que ser 'production' para ativar cookies seguros e obrigatoriedade do JWT_SECRET.
NODE_ENV=production

# Porta HTTP. O Railway injeta automaticamente, não precisas de definir lá.
PORT=3000

# Segredo usado para assinar os JWT. Gera uma string longa e aleatória, ex.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troca-isto-por-um-segredo-longo-e-aleatorio

# Caminho absoluto para o ficheiro SQLite. No Railway aponta para o volume persistente.
DATABASE_PATH=/data/portal.db

# (Opcional) Envio real de emails via Resend — https://resend.com
# Sem chave, os emails continuam a ficar apenas na consola e na tabela `notifications`.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=DUIT <no-reply@duit.pt>
